# =============================================================
# .env.example — Copy to .env and fill in your values
# Run `scripts/init_dev.sh` to auto-generate UID/GID and GPG vars
# =============================================================

# --- Host user IDs (prevents volume permission issues) ---
UID=1000
GID=1000

# --- PostgreSQL ---
POSTGRES_DB=modestdb
POSTGRES_USER=modestuser
POSTGRES_PASSWORD=changeme

# --- Nginx exposed port (host side) ---
NGINX_PORT=8080

# --- GPG ---
# Path to the developer's local GPG home directory
GPG_HOME=~/.gnupg
# The key ID to use for signing (populated by init_dev.sh)
GPG_KEY_ID=

# --- Test Framework Rotation ---
# Set to 'unittest' or 'pytest' to select the Dockerfile stage
TEST_FRAMEWORK=pytest

# --- Staging (populated automatically by the commit-msg hook) ---
COMMIT_SHORT_ID=
COMMIT_TIMESTAMP=
