# =============================================================
# .env.example — Copy to .env and fill in your values
# Run `scripts/init_dev.sh` to auto-generate UID/GID and GPG vars
# =============================================================

# --- Host user IDs (prevents volume permission issues) ---
UID=1000
GID=1000 

# --- PostgreSQL ---
POSTGRES_DB=modestdb
POSTGRES_USER=modestuser
POSTGRES_PASSWORD=changeme

# --- Nginx exposed port (host side) ---
NGINX_PORT=3000
NGINX_PORT_STAGING=3001

# --- GPG ---
# Path to the developer's local GPG home directory
GPG_HOME=~/.gnupg
# The key ID to use for signing (populated by init_dev.sh)
GPG_KEY_ID=

# --- Test Framework Rotation ---
# Set to 'unittest' or 'pytest' to select the Dockerfile stage
TEST_FRAMEWORK=pytest

# --- Staging (populated automatically by the commit-msg hook) ---
COMMIT_SHORT_ID=
COMMIT_TIMESTAMP=

# =============================================================
# Quality Thresholds — configure min/max behaviour for each tool
# =============================================================

# ---- pylint (pre-commit gate + staging) ----
# Min acceptable score: 0.0 – 10.0   (default: 7.0)
PYLINT_MIN_SCORE=7.0

# ---- mypy (pre-commit gate + staging) ----
# Options: strict | standard  (default: standard)
MYPY_MODE=standard

# ---- coverage (staging) ----
# Minimum branch coverage %: 0 – 100  (default: 70)
COVERAGE_MIN=70

# ---- bandit (staging security scan) ----
# Minimum severity to report: LOW | MEDIUM | HIGH  (default: LOW = report all)
BANDIT_LEVEL=low
# Minimum confidence to report: LOW | MEDIUM | HIGH  (default: LOW = report all)
BANDIT_CONFIDENCE=low

# ---- radon (staging maintainability) ----
# Minimum maintainability grade: A | B | C | D | E | F  (default: B)
# Radon grades: A (>20), B (10–20), C (0–10), D (<0)
RADON_MIN_GRADE=B

# ---- hadolint (Dockerfile linter) ----
# Severity threshold: error | warning | info | style | ignore  (default: error)
# 'error'=only block on errors; 'style'=most permissive gate
HADOLINT_FAILURE_THRESHOLD=error
